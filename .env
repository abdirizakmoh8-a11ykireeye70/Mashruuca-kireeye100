# ============================================================
#  KIREEYE — Environment Variables
#  Koobiyo .env.example → .env kadibna xogta geli
# ============================================================

# Firebase
FIREBASE_API_KEY=AIzaSy_YOUR_KEY_HERE
FIREBASE_AUTH_DOMAIN=kireeye.firebaseapp.com
FIREBASE_PROJECT_ID=kireeye
FIREBASE_STORAGE_BUCKET=kireeye.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:android:abcdef
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Sign In
GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# Maps
GOOGLE_MAPS_API_KEY=YOUR_MAPS_KEY

# reCAPTCHA (App Check)
RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_KEY

# Translate (Chat auto-translation)
GOOGLE_TRANSLATE_KEY=YOUR_TRANSLATE_KEY

# Claude AI (Help Center)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY
